{
  "name": "Market Intelligence Dark Theme",
  "dataColors": ["#118DFF", "#12239E", "#11B683", "#E044A7", "#0A2240", "#7F7F7F", "#F2F2F2", "#1F82A4"],
  "background": "#0F172A",
  "foreground": "#E2E8F0",
  "tableAccent": "#1E293B",
  "visualStyles": {
    "*": {
      "*": {
        "background": [{"show": true, "color": {"solid": {"color": "#1E293B"}}, "transparency": 0}],
